generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String        @id
  email        String        @unique
  credits      Int           @default(10)
  plan         String        @default("free")
  createdAt    DateTime      @default(now())
  transactions Transaction[]
}

model Transaction {
  id        String   @id @default(cuid())
  userId    String
  amount    Float
  credits   Int
  stripeId  String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])
}
